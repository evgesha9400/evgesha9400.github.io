{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evgesha9400.github.io/schemas/library-manifest-1.0.schema.json",
  "title": "Library documentation manifest",
  "description": "The version 1 durable editorial contract for docs/library.yml in an allowlisted library repository.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "library_id",
    "title",
    "pitch",
    "repository",
    "repository_url",
    "package",
    "status",
    "categories"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Manifest contract version."
    },
    "library_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Exact key in the portal's allowlisted library catalogue."
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 &+./'()-]{2,99}$",
      "description": "Plain-text library title for developers."
    },
    "pitch": {
      "type": "string",
      "minLength": 20,
      "maxLength": 280,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 ,.&+/'()!?;:-]{19,279}$",
      "description": "Plain-text, developer-first library summary without markup."
    },
    "repository": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]{0,38}/[a-z0-9][a-z0-9._-]{0,99}$",
      "description": "GitHub owner/repository identity, not a URL."
    },
    "repository_url": {
      "type": "string",
      "minLength": 20,
      "maxLength": 160,
      "pattern": "^https://github\\.com/[a-z0-9][a-z0-9.-]{0,38}/[a-z0-9][a-z0-9._-]{0,99}$",
      "description": "Canonical HTTPS GitHub repository URL, checked against repository."
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "description": "PyPI package name; the portal derives pip install <name>."
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["planned", "published", "deprecated"],
      "description": "Current documentation publication status."
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 48,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9 &+./-]{1,47}$"
      },
      "description": "Non-empty plain-text categories for developer discovery."
    }
  }
}
